{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "twtGUI (gdb, external console)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/twtGUI.exe",
      "args": [],
      "cwd": "${workspaceFolder}/build",
      "externalConsole": true,
      "MIMode": "gdb",
      "miDebuggerPath": "C:/Qt/Tools/mingw1310_64/bin/gdb.exe",
      "setupCommands": [
        { "description": "Enable pretty-printing", "text": "-enable-pretty-printing", "ignoreFailures": true }
      ],
      "stopAtEntry": false,
      "environment": [
        { "name": "QT_QPA_PLATFORM_PLUGIN_PATH", "value": "C:/Qt/6.10.1/mingw_64/plugins/platforms" },
        { "name": "PATH", "value": "${env:PATH};C:\\Qt\\6.10.1\\mingw_64\\bin;C:\\Qt\\Tools\\mingw1310_64\\bin" }
      ]
    }
  ]
}
